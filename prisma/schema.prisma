generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model rooms {
  id          String    @id
  type        String
  title       String?
  lastChatId  Int       @default(0)
  memberCount Int
  updatedAt   String
  createdAt   DateTime  @default(now())
  members     members[]

  @@index([updatedAt])
  @@map("room")
}

model members {
  userId     String
  roomId     String
  lastChatId Int    @default(0)
  rooms      rooms  @relation(fields: [roomId], references: [id])

  @@id([userId, roomId])
  @@map("member")
}

model friends {
  userId    String
  friendId  String
  isFriend  Boolean
  createdAt DateTime @default(now())

  @@id([userId, friendId])
  @@index([userId, isFriend])
  @@map("friend")
}
